# Production environment variables for Charon.
# Copy this file to .env.prod and fill in all values before starting the stack.
# NEVER commit .env.prod to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=charon
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=charon_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CACHE_TTL=300
REDIS_PUBSUB_CHANNEL_RATES=rates.ingested
REDIS_PUBSUB_CHANNEL_SIGNALS=signals.updated

# ── Miner ─────────────────────────────────────────────────────────────────────
REFRESH_SECONDS=3600

# ── Ports exposed on the host ─────────────────────────────────────────────────
API_PORT=8000
FRONTEND_PORT=8501

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Europe/Warsaw
